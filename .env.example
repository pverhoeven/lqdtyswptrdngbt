# Kopieer dit bestand naar .env en vul je eigen waarden in.
# .env wordt NOOIT gecommit (staat in .gitignore).

# OKX API credentials (aanmaken via OKX → API Management)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Telegram bot (aanmaken via @BotFather op Telegram)
# chat_id: stuur een bericht naar je bot en open:
#   https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
